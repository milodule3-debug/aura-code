# aura-code — API keys
# Copy to .env in project root, or use ~/.hermes/.env (auto-loaded on startup).
# Never commit real keys to git.

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT models)
OPENAI_API_KEY=sk-...

# Google (Gemini models)
GOOGLE_API_KEY=...

# xAI (Grok models)
XAI_API_KEY=...

# OpenRouter (access to many models via one key)
OPENROUTER_API_KEY=sk-or-...

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...

# Xiaomi MiMo — platform.xiaomimimo.com/api-keys
XIAOMI_API_KEY=tp-...
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Default model (CLI: --model or :model in REPL)
# AURA_MODEL=deepseek/deepseek-v4-flash
